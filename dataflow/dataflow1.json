{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText9",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DelimitedText10",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Index as integer,",
				"          Name as string,",
				"          Description as string,",
				"          Brand as string,",
				"          Category as string,",
				"          Price as integer,",
				"          Currency as string,",
				"          Stock as integer,",
				"          EAN as string,",
				"          Color as string,",
				"          Size as string,",
				"          Availability as string,",
				"          {Internal ID} as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          Index,",
				"          Name,",
				"          Description,",
				"          Price,",
				"          Stock",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 filter(Index<=20) ~> filter1",
				"filter1 aggregate(Price = sum(Price)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Index as string,",
				"          Name as string,",
				"          Description as string,",
				"          Brand as string,",
				"          Category as string,",
				"          Price as string,",
				"          Currency as string,",
				"          Stock as string,",
				"          EAN as string,",
				"          Color as string,",
				"          Size as string,",
				"          Availability as string,",
				"          {Internal ID} as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}